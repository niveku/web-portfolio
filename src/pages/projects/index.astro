---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = ['All', 'Geospatial', 'Data Engineering', 'AI/Automation'] as const;
---

<BaseLayout title="Projects | Geospatial Data Engineering, Data Engineering & AI Workflows" description="Geospatial and GIS systems, AWS data pipelines for enterprise clients, and AI workflow automation by Kevin Henao. Built with Python, QGIS, GeoPandas, and AWS.">
  <section>
    <h1>Projects</h1>
    <p>
      Work I shipped as a geospatial data engineer and geoscientist. GIS systems and
      spatial data pipelines from the DIMAR and Fura years, AWS data pipelines for
      enterprise clients at Arkho, and AI workflow automation on the side. Every card
      names the client, the stack, and the problem it solved.
    </p>

    <nav aria-label="Filter by category">
      {categories.map((cat) => (
        <button data-filter={cat === 'All' ? '' : cat}>
          {cat}
        </button>
      ))}
    </nav>

    <div id="projects-grid" class="card-grid">
      {sorted.map((project) => (
        <ProjectCard
          title={project.data.title}
          summary={project.data.summary}
          category={project.data.category}
          stack={project.data.stack}
          slug={project.id}
        />
      ))}
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const cards = document.querySelectorAll<HTMLElement>('[data-category]');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? '';
        cards.forEach((card) => {
          const visible = filter === '' || card.dataset.category === filter;
          card.style.display = visible ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
