---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = ['All', 'Geospatial', 'Data Engineering', 'AI/Automation'] as const;
---

<BaseLayout title="Projects | Geospatial Data Engineering, Spatial Data Pipelines & AWS" description="Geospatial data engineering by Kevin Henao: GIS systems, AWS pipelines for AB InBev and Casaideas, and the first 3D model of the Coscuez emerald deposit. Python, QGIS, GeoPandas, AWS.">
  <section>
    <h1>Projects</h1>
    <p>
      I have spent eight years as a geospatial data engineer and geoscientist. I built the
      first 3D geological model of the Coscuez emerald deposit and ArcGIS monitoring
      workflows for Colombia's maritime authority (DIMAR). At Arkho I shipped the AB InBev
      invoice pipeline that normalized 30 to 40 supplier formats with Textract and Step
      Functions, then the Casaideas SAP-to-cloud flow on Glue and PySpark. Each card below
      names the client, the stack, and the problem the work solved.
    </p>

    <nav aria-label="Filter by category">
      {categories.map((cat) => (
        <button data-filter={cat === 'All' ? '' : cat}>
          {cat}
        </button>
      ))}
    </nav>

    <div id="projects-grid" class="card-grid">
      {sorted.map((project) => (
        <ProjectCard
          title={project.data.title}
          summary={project.data.summary}
          category={project.data.category}
          stack={project.data.stack}
          slug={project.id}
        />
      ))}
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const cards = document.querySelectorAll<HTMLElement>('[data-category]');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? '';
        cards.forEach((card) => {
          const visible = filter === '' || card.dataset.category === filter;
          card.style.display = visible ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
