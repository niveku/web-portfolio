---
// Niveku home — Yofukashi-inspired neon portfolio.
// Standalone page (does NOT use BaseLayout): it ships its own nav/footer and
// dark design tokens. The interactive UI is a single React island, server-
// rendered for SEO and hydrated on load.
import '../styles/niveku/tokens.css';
import '../styles/niveku/layout.css';
import '../styles/niveku/strata.css';
import App from '../components/niveku/App.jsx';

const title = 'Niveku — Kevin Henao · data, gis, ai automation';
const description =
  'Geoscientist turned data & GIS engineer. Spatial workflows, AWS pipelines, and AI automation — from Bogotá, remote-first.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="city-bg"></div>
    <div class="city-grain"></div>
    <div class="city-scanline"></div>

    <App client:load />
  </body>
</html>
