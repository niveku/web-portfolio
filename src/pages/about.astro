---
import BaseLayout from '../layouts/BaseLayout.astro';
import { career } from '../data/career';
import { profilePageSchema, breadcrumbSchema } from '../lib/seo';

const site = Astro.site ?? new URL('https://portafolio-niveku.vercel.app');
const url = new URL(Astro.url.pathname, site);
const { identity, experience, skills, education, certifications, publications, softSkills } = career;

const schemas = [
  profilePageSchema(site, url),
  breadcrumbSchema([
    { name: 'Home', url: new URL('/', site) },
    { name: 'About', url },
  ]),
];

const fmtRange = (s: string, e: string) => `${s} – ${e}`;
---

<BaseLayout
  title="About"
  description="Kevin Henao, geospatial data engineer and geoscientist, 8+ years across GIS (QGIS, ArcGIS, GeoPandas), Python, and AWS spatial data pipelines. Built the first 3D model of the Coscuez emerald deposit; SPE co-author, ADIPEC 2025. Bogotá, remote-first."
  type="profile"
  schemas={schemas}
>
  <article>
    <h1>About · Kevin Henao</h1>

    <section>
      <h2>Who I am</h2>
      <p>
        I'm a <strong>geospatial data engineer</strong> who started as a geoscientist.
        I studied Geosciences at Universidad de los Andes (GPA 4.12/5, on the "Quiero
        Estudiar" scholarship) and hold a CPG license. My first job was field geology
        in Colombia's emerald belt: core logging, structural mapping, and 3D ore
        modeling in Leapfrog and Datamine. Reporting ran on QGIS and hand-built
        Python, so I automated map and report production and gave Fura back about
        100 hours a year. Over 8+ years I moved from geological
        reporting into operational GIS, then into cloud data engineering on AWS.
      </p>
      <p>
        I take domain-heavy, ambiguous problems and ship systems that run in
        production. At Fura I built the first 3D geological model of the Coscuez
        emerald deposit, the basis for the company's first formal Colombian emerald
        resource estimation. At DIMAR, Colombia's maritime authority, institutional planners had no single
        view of operational status during COVID, so I shipped a monitoring
        workflow on ArcGIS Online, Survey123, and GeoPandas, and released ViENOS, an
        open-source Python/Dash dashboard (MIT) for tracking El Niño and La Niña on the
        Pacific coast.
      </p>
      <p>
        At Arkho I took the acting-architect role on AB InBev invoice automation, where
        supplier PDFs arrived in 30–40 incompatible layouts. I designed the pipeline that
        normalized them into structured data on AWS Textract, Lambda, and Step
        Functions. I also built the Casaideas SAP-to-cloud pipeline on Glue, PySpark,
        and S3, and contributed to Coca-Cola Chile distribution ETL under quality-gated
        DevOps, shipping 15+ ETLs across 4 AWS CDK projects and 20+ Redshift reports.
        At Imaged Reality I extended the Stratbox Python API for depth-referenced
        extraction and trained a Random Forest facies classifier on borehole core
        imagery. That pipeline became the technical core of <em>"Automating Core Data
        Integration: Insights from the Volve Field Case Study"</em>, which I co-authored
        for ADIPEC 2025 (SPE OnePetro D041S138R004).
      </p>
    </section>

    <section>
      <h2>Experience</h2>
      {experience.map((job) => (
        <article class="role">
          <h3>{job.role} · {job.company}</h3>
          <p class="meta">
            {fmtRange(job.start, job.end)} · {job.location} · {job.type}
          </p>
          <p>{job.summary}</p>
          {job.highlights.length > 0 && (
            <ul>{job.highlights.map((h) => <li>{h}</li>)}</ul>
          )}
        </article>
      ))}
    </section>

    <section>
      <h2>What I work with</h2>
      {skills.categories.map((cat) => (
        <div class="skill-cat">
          <h3>{cat.name}</h3>
          <p>{cat.items.join(' · ')}</p>
        </div>
      ))}
    </section>

    <section>
      <h2>How I work</h2>
      <ul>{softSkills.map((s) => <li>{s}</li>)}</ul>
    </section>

    <section>
      <h2>Education</h2>
      <ul>
        {education.map((e) => (
          <li>
            <strong>{e.degree}</strong> · {e.institution} ({fmtRange(e.start, e.end)})
            {e.gpa && <> · GPA {e.gpa}</>}
            {e.honors && e.honors.length > 0 && <> · {e.honors.join('; ')}</>}
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Certifications & credentials</h2>
      <ul>
        {certifications.map((c) => (
          <li>{c.name} · {c.issuer}{c.year && <> ({c.year})</>}</li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Publication</h2>
      <ul>
        {publications.map((p) => (
          <li>
            {p.role}, <em>{p.title}</em>. {p.venue}, {p.year}. {p.identifier}.
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Languages & context</h2>
      <p>
        {identity.languages.map((l) => `${l.language} (${l.level})`).join(' · ')}.
      </p>
      <p>I work from {identity.location}, remote-first since 2021.</p>
    </section>
  </article>
</BaseLayout>
