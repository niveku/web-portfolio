---
import BaseLayout from '../layouts/BaseLayout.astro';
import { career } from '../data/career';
import { profilePageSchema, breadcrumbSchema } from '../lib/seo';

const site = Astro.site ?? new URL('https://portafolio-niveku.vercel.app');
const url = new URL(Astro.url.pathname, site);
const { identity, experience, skills, education, certifications, publications, softSkills } = career;

const schemas = [
  profilePageSchema(site, url),
  breadcrumbSchema([
    { name: 'Home', url: new URL('/', site) },
    { name: 'About', url },
  ]),
];

const fmtRange = (s: string, e: string) => `${s} – ${e}`;
---

<BaseLayout
  title="About"
  description="Kevin Henao — geospatial data engineer and geoscientist (8+ years): GIS, Python/GeoPandas, AWS data pipelines, and AI-assisted workflows. Bogotá, remote-first."
  type="profile"
  schemas={schemas}
>
  <article>
    <h1>About — Kevin Henao</h1>

    <section>
      <h2>Who I am</h2>
      <p>
        I'm a <strong>geospatial data engineer</strong> who started as a geoscientist.
        I studied Geosciences at Universidad de los Andes, then spent my first years
        in field geology and 3D ore modeling — work that pulled me into Python, GIS,
        and spatial data. Over 8+ years I grew from geological reporting and map
        production into operational GIS, cloud data engineering on AWS, and, more
        recently, AI-assisted workflow automation.
      </p>
      <p>
        The throughline is translating domain-heavy, ambiguous problems into working
        technical systems — a serverless invoice pipeline normalizing 30–40 supplier
        formats, COVID geospatial monitoring for a national government agency, the
        first 3D geological model of an emerald deposit, and a Random Forest facies
        classifier that became the technical core of an SPE paper.
      </p>
      <p>
        I'm a co-author of <em>"Automating Core Data Integration: Insights from the
        Volve Field Case Study"</em>, presented at ADIPEC 2025 (SPE OnePetro
        D041S138R004), applying machine learning to geoscience data workflows.
      </p>
    </section>

    <section>
      <h2>Experience</h2>
      {experience.map((job) => (
        <article class="role">
          <h3>{job.role} — {job.company}</h3>
          <p class="meta">
            {fmtRange(job.start, job.end)} · {job.location} · {job.type}
          </p>
          <p>{job.summary}</p>
          {job.highlights.length > 0 && (
            <ul>{job.highlights.map((h) => <li>{h}</li>)}</ul>
          )}
        </article>
      ))}
    </section>

    <section>
      <h2>What I work with</h2>
      {skills.categories.map((cat) => (
        <div class="skill-cat">
          <h3>{cat.name}</h3>
          <p>{cat.items.join(' · ')}</p>
        </div>
      ))}
    </section>

    <section>
      <h2>How I work</h2>
      <ul>{softSkills.map((s) => <li>{s}</li>)}</ul>
    </section>

    <section>
      <h2>Education</h2>
      <ul>
        {education.map((e) => (
          <li>
            <strong>{e.degree}</strong> — {e.institution} ({fmtRange(e.start, e.end)})
            {e.gpa && <> · GPA {e.gpa}</>}
            {e.honors && e.honors.length > 0 && <> · {e.honors.join('; ')}</>}
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Certifications & credentials</h2>
      <ul>
        {certifications.map((c) => (
          <li>{c.name} — {c.issuer}{c.year && <> ({c.year})</>}</li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Publication</h2>
      <ul>
        {publications.map((p) => (
          <li>
            {p.role}, <em>{p.title}</em>. {p.venue}, {p.year}. {p.identifier}.
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Languages & context</h2>
      <p>
        {identity.languages.map((l) => `${l.language} (${l.level})`).join(' · ')}.
      </p>
      <p>Based in {identity.location}. Remote-first since 2021.</p>
    </section>
  </article>
</BaseLayout>
