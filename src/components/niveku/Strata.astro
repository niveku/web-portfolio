---
/* Career as a stratigraphic column — static; hover/focus reveals the log (CSS). */
import StrataPattern from './StrataPattern.astro';

const STRATA_ACCENT: Record<string, string> = {
  magenta: 'oklch(0.80 0.20 340)',
  violet: 'oklch(0.74 0.17 300)',
  blue: 'oklch(0.72 0.16 262)',
  cyan: 'oklch(0.82 0.13 200)',
  amber: 'oklch(0.82 0.13 78)',
};

const STRATA = [
  {
    id: 'ai', era: 'AI · AUTOMATION', kana: '知能', formation: 'Recent Overprint',
    rock: 'conglomerate', rockLabel: 'Conglomerate', ageLabel: '2024 → now', thickness: 8, color: 'magenta',
    lithology: ['Claude Code', 'MCPs', 'Agents', 'Skills', 'Python'],
    events: [
      'OpenClaw · personal AI automation system on Claude Code',
      'MCP servers and custom skills across dev, writing, and knowledge work',
      'AI-assisted delivery folded into daily engineering',
    ],
    narrative: 'A thin surface layer, still being deposited. Side-practice AI tooling I build on the Claude stack, sitting on top of the production work below.',
  },
  {
    id: 'product', era: 'GEOSCIENCE SOFTWARE', kana: '製品', formation: 'Stratbox Formation',
    rock: 'limestone', rockLabel: 'Limestone', ageLabel: '2024 → now', thickness: 16, color: 'amber',
    lithology: ['Python', 'scikit-learn', 'Product / QA', 'Jira', 'PostgreSQL'],
    events: [
      'SPE paper at ADIPEC 2025 · Volve Field core data (D041S138R004)',
      'Random Forest facies classification pipeline · scikit-learn',
      'Designed the Jira bug-reporting and QA process',
      '~20 product onboardings for enterprise oil & gas teams',
    ],
    narrative: 'Well-cemented and current. Geoscience software at Imaged Reality, where I sit between enterprise oil and gas clients, the product, and the Python that ships.',
  },
  {
    id: 'data', era: 'DATA ENGINEERING', kana: '配管', formation: 'Pipeline Sandstone',
    rock: 'sandstone', rockLabel: 'Sandstone', ageLabel: '2021 → 2024', thickness: 22, color: 'violet',
    lithology: ['AWS Lambda', 'Step Functions', 'Glue', 'PySpark', 'Redshift', 'S3', 'Python', 'SQL'],
    events: [
      'AB InBev · serverless invoice automation across 30–40 supplier formats (acting architect)',
      'Casaideas · SAP-to-cloud pipeline (Glue, PySpark, S3)',
      'Coca-Cola Chile · distribution ETL under quality-gated DevOps',
      '15+ ETLs across 4 CDK projects · 20+ Redshift reports',
    ],
    narrative: 'Porous and permeable, the reservoir of the section. Thick, well-bedded AWS pipelines at Arkho that moved retail, beverage, and document data at production scale.',
  },
  {
    id: 'gis', era: 'GEOSPATIAL · GIS', kana: '地理', formation: 'Cartographic Shale',
    rock: 'shale', rockLabel: 'Shale', ageLabel: '2019 → 2021', thickness: 18, color: 'cyan',
    lithology: ['ArcGIS Online', 'ArcGIS Pro', 'QGIS', 'GeoPandas', 'Survey123', 'Dash', 'Power BI'],
    events: [
      'ViENOS · open-source ENSO oceanographic dashboard (Python/Dash, MIT)',
      'COVID geospatial monitoring workflow for the national maritime authority',
      'Pacific expedition environmental mapping',
      'Power BI dashboards in a Ministry of Energy and Mines context',
    ],
    narrative: 'Finely laminated, one map bedded over the next. Operational GIS and dashboards at DIMAR and Heinsohn that institutions and ministries put to work.',
  },
  {
    id: 'geo', era: 'GEOSCIENCE', kana: '地質', formation: 'Andes Basement',
    rock: 'basement', rockLabel: 'Crystalline basement', ageLabel: '2013 → 2019', thickness: 26, color: 'blue',
    lithology: ['Field geology', 'Stratigraphy', 'Geochemistry', 'Leapfrog', 'Datamine', 'Python'],
    events: [
      'First 3D geological model of the Coscuez emerald deposit',
      '~100 hours/year saved by automating reporting in Python',
      'BSc Geosciences · Universidad de los Andes (4.12/5)',
      'Colombian Professional Geology License (CPG)',
    ],
    narrative: 'Crystalline basement, deformed and intruded, the foundation under everything above. Field geology, stratigraphy, and emerald resource modeling at Fura, where the domain intuition formed.',
  },
];
---
<section id="strata" class="sec sec-strata">
  <div class="shell">
    <header class="sec-head strata-head">
      <div>
        <div class="kicker">CAREER CROSS-SECTION <span class="kana" style="margin-left:8px">断面図</span></div>
        <h2 class="sec-title">
          Read me like a <span class="neon-amber">stratigraphic column</span>.
        </h2>
        <p class="sec-lede">
          I still think in formations and ages, so my career stacks like a
          stratigraphic column: youngest at the surface, geoscience basement at
          depth. Hover or focus a bed to read the log.
        </p>
      </div>
      <div class="strata-legend">
        <div class="kicker strata-legend-title">LITHOLOGY KEY <span class="kana" style="margin-left:8px">凡例</span></div>
        {STRATA.map((l) => (
          <div class="strata-legend-row" style={`--layer-accent: ${STRATA_ACCENT[l.color]}`}>
            <span class="strata-legend-box">
              <StrataPattern rock={l.rock} color={l.color} idSuffix={`leg-${l.id}`} />
            </span>
            <span class="strata-legend-name">{l.rockLabel}</span>
          </div>
        ))}
      </div>
    </header>

    <div class="strata-column glass">
      <div class="strata-scale">
        <div class="strata-scale-head">
          <span class="kana">深度</span>
          <span class="kicker">DEPTH / AGE</span>
        </div>
        <div class="strata-scale-ruler" aria-hidden="true">
          {Array.from({ length: 11 }).map((_, i) => (
            <div class={`strata-tick ${i % 5 === 0 ? 'strata-tick-maj' : ''}`}>
              <span>{i === 0 ? 'SURFACE' : i === 10 ? 'BASEMENT' : ''}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="strata-beds">
        {STRATA.map((layer) => (
          <div
            class="strata-layer"
            tabindex="0"
            style={`--layer-accent: ${STRATA_ACCENT[layer.color]}; --bed-h: ${54 + layer.thickness * 2}px`}
          >
            <div class="strata-bed">
              <div class="strata-bed-pattern">
                <StrataPattern rock={layer.rock} color={layer.color} idSuffix={layer.id} />
              </div>
              <div class="strata-bed-head">
                <div class="strata-bed-meta">
                  <span class="kicker strata-era">{layer.era}</span>
                </div>
                <h3 class="strata-formation">{layer.formation}</h3>
                <div class="strata-rockline">
                  <span class="strata-rock">{layer.rockLabel}</span>
                  <span class="strata-dot">·</span>
                  <span class="strata-age">{layer.ageLabel}</span>
                </div>
              </div>
              <div class="strata-bed-right">
                <div class="strata-lith">
                  {layer.lithology.slice(0, 4).map((l) => <span class="chip chip-thin">{l}</span>)}
                  {layer.lithology.length > 4 && (
                    <span class="chip chip-thin chip-more">+{layer.lithology.length - 4}</span>
                  )}
                </div>
              </div>
            </div>

            <div class="strata-detail">
              <p class="strata-narr">{layer.narrative}</p>
              <ul class="strata-events">
                {layer.events.map((e) => <li>{e}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <div class="strata-footer">
        <span class="kana" style="margin-right:10px">総合</span>
        <span class="kicker">SUMMARY</span>
        <span class="strata-footer-text">
          8+ years shipping · 5 formations · <span class="strata-footer-claim">I take ambiguous,
          domain-heavy problems and ship them as working technical systems.</span>
        </span>
      </div>
    </div>
  </div>
</section>
