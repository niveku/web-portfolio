---
import Terminal from './Terminal.jsx';
import { SKILLS } from './data.js';
---
<section id="about" class="sec sec-about">
  <div class="shell">
    <header class="sec-head about-head">
      <div>
        <div class="kicker">ABOUT <span class="kana" style="margin-left:8px">紹介</span></div>
        <h2 class="sec-title">
          Rocks to <span class="neon-cyan">maps</span> to <span class="neon-magenta">pipelines</span>.
        </h2>
      </div>
      <div class="about-meta about-meta-top">
        <div><span class="kicker">Base</span><span>Bogotá · remote-first</span></div>
        <div><span class="kicker">Lang</span><span>EN C2 · ES nativo</span></div>
        <div><span class="kicker">Cred</span><span>BSc Geo · CPG</span></div>
        <div><span class="kicker">Paper</span><span>ADIPEC 2025</span></div>
      </div>
    </header>

    <div class="about-terminal-wrap">
      <Terminal client:visible />
    </div>

    <div class="about-grid">
      <div class="about-lead glass">
        <div class="kicker">BIO</div>
        <p class="about-para">
          I'm a geoscientist who became a geospatial data engineer. Universidad de
          los Andes, then field geology and 3D ore modeling — which pulled me into
          <em> Python, GIS, and spatial data</em>: QGIS, GeoPandas, PostGIS, GDAL,
          raster and vector. Eight years on, I build geospatial and spatial-ETL
          pipelines, GIS systems institutions actually use, and AWS data
          infrastructure (Lambda, Glue, Step Functions, Textract).
        </p>
        <p class="about-para">
          The throughline is turning domain-heavy, ambiguous problems into working
          systems — a serverless invoice pipeline across 30–40 supplier formats,
          COVID geospatial monitoring for a government agency, a Random Forest
          facies model that became an SPE paper. I scope it, build it, and explain
          the tradeoffs out loud.
        </p>
      </div>

      <div class="skills glass">
        <div class="kicker">STACK</div>
        <div class="skills-group">
          <h4><span class="dot dot-mag"></span> Strong · production-proven</h4>
          <div class="chips">
            {SKILLS.strong.map((s) => <span class="chip chip-mag">{s}</span>)}
          </div>
        </div>
        <div class="skills-group">
          <h4><span class="dot dot-cyan"></span> Credible · with framing</h4>
          <div class="chips">
            {SKILLS.credible.map((s) => <span class="chip chip-cyan">{s}</span>)}
          </div>
        </div>
        <div class="skills-group">
          <h4><span class="dot dot-amber"></span> Growing</h4>
          <div class="chips">
            {SKILLS.growing.map((s) => <span class="chip chip-amber">{s}</span>)}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
