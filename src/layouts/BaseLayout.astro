---
import '../styles/global.css';
import '../styles/niveku/tokens.css';
import '../styles/pages.css';
import Seo from '../components/seo/Seo.astro';
import { personSchema, websiteSchema } from '../lib/seo';
import { career } from '../data/career';

const fontHref =
  'https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article' | 'profile';
  /** Page-specific JSON-LD, appended to the site-wide Person + WebSite graph. */
  schemas?: Record<string, unknown>[];
  image?: string;
}

const {
  title,
  description = career.identity.tagline,
  type = 'website',
  schemas = [],
  image,
} = Astro.props;

const canonicalTitle =
  title === 'Home'
    ? `${career.identity.displayName} — ${career.identity.positioning.lead}`
    : `${title} — ${career.identity.displayName}`;

const baseSchemas = [personSchema(Astro.site), websiteSchema(Astro.site)];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Seo
      title={canonicalTitle}
      description={description}
      type={type}
      image={image}
      schemas={[...baseSchemas, ...schemas]}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={fontHref} onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href={fontHref} /></noscript>
  </head>
  <body>
    <header>
      <nav id="site-nav">
        <a href="/">Niveku</a>
        <button
          class="bl-burger"
          id="site-burger"
          type="button"
          aria-expanded="false"
          aria-controls="site-menu"
          aria-label="Open menu"
        >
          <span></span><span></span><span></span>
        </button>
        <ul id="site-menu">
          <li><a href="/about">About</a></li>
          <li><a href="/projects">Projects</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact" class="bl-cta">Contact →</a></li>
        </ul>
      </nav>
      <div class="bl-backdrop" id="site-backdrop" hidden></div>
    </header>

    <script is:inline>
      (function () {
        const nav = document.getElementById('site-nav');
        const btn = document.getElementById('site-burger');
        const menu = document.getElementById('site-menu');
        const backdrop = document.getElementById('site-backdrop');
        if (!nav || !btn || !menu) return;

        const open = () => {
          nav.setAttribute('data-open', 'true');
          btn.setAttribute('aria-expanded', 'true');
          btn.setAttribute('aria-label', 'Close menu');
          document.body.style.overflow = 'hidden';
          if (backdrop) backdrop.hidden = false;
        };
        const close = () => {
          nav.removeAttribute('data-open');
          btn.setAttribute('aria-expanded', 'false');
          btn.setAttribute('aria-label', 'Open menu');
          document.body.style.overflow = '';
          if (backdrop) backdrop.hidden = true;
        };
        const toggle = () => (nav.hasAttribute('data-open') ? close() : open());

        btn.addEventListener('click', toggle);
        if (backdrop) backdrop.addEventListener('click', close);
        menu.addEventListener('click', (e) => {
          if (e.target.closest('a')) close();
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && nav.hasAttribute('data-open')) {
            close();
            btn.focus();
          }
        });
        const mq = window.matchMedia('(min-width: 721px)');
        mq.addEventListener('change', (e) => {
          if (e.matches) close();
        });
      })();
    </script>

    <main>
      <slot />
    </main>

    <footer>
      <p>
        Kevin Henao &middot; {career.identity.positioning.lead} &middot; Bogotá, Colombia &middot;
        Remote-first
      </p>
    </footer>
  </body>
</html>
